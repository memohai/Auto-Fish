<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.AutoFish" parent="Theme.Material3.DayNight.NoActionBar" />

    <style name="Theme.AutoFish.Light" parent="Theme.Material3.Light.NoActionBar">
        <item name="android:windowBackground">@color/autofish_light_background</item>
    </style>

    <style name="Theme.AutoFish.Dark" parent="Theme.Material3.Dark.NoActionBar">
        <item name="android:windowBackground">@color/autofish_dark_background</item>
    </style>

    <!-- Fixed launch background to prevent visible black/white jump on startup. -->
    <style name="Theme.AutoFish.Launch" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:windowBackground">@color/autofish_launch_background</item>
        <item name="android:windowSplashScreenBackground">@color/autofish_launch_background</item>
    </style>
</resources>
